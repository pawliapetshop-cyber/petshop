<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <title>Login Admin</title>
  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    body {
      background: linear-gradient(135deg, #f4f7f1, #dfeee5);
      min-height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      padding: 24px;
    }

    .login-card {
      width: 100%;
      max-width: 380px;
      border-radius: 22px;
      overflow: hidden;
    }

    .brand-logo {
      width: 96px;
      height: 96px;
      object-fit: contain;
      border-radius: 18px;
      background: #fff;
      padding: 10px;
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
    }
  </style>
</head>

<body>

<div class="card login-card border-0 shadow">
  <div class="card-body p-4 p-md-5">
    <div class="text-center mb-4">
      <img src="/logo.jpeg" alt="Pawlia" class="brand-logo mb-3">
      <h3 class="mb-1">Pawlia Admin</h3>
      <p class="text-muted mb-0">Accede al panel interno de pedidos y catalogo.</p>
    </div>

    <% if (errorMessage) { %>
      <div class="alert alert-danger py-2">
        <%= errorMessage %>
      </div>
    <% } %>

    <form method="POST">
      <input type="hidden" name="_csrf" value="<%= csrfToken %>">

      <div class="mb-3">
        <label class="form-label">Correo</label>
        <input
          type="email"
          name="email"
          class="form-control"
          placeholder="Correo"
          value="<%= email || '' %>"
          required
        >
      </div>

      <div class="mb-4">
        <label class="form-label">Contrasena</label>
        <input
          type="password"
          name="password"
          class="form-control"
          placeholder="Contrasena"
          required
        >
      </div>

      <button class="btn btn-success w-100">Ingresar</button>
    </form>
  </div>
</div>

</body>
</html>
