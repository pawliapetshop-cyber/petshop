<h2 class="mb-4">Editar Producto</h2>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %>">
    <%= flash.message %>
  </div>
<% } %>

<% if (errorMessages && errorMessages.length > 0) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errorMessages.forEach(message => { %>
        <li><%= message %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<%
  const currentVariants = (formData?.variants && formData.variants.length > 0)
    ? formData.variants
    : ((product.ProductVariants || []).map(variant => ({
      id: variant.id,
      name: variant.name,
      stock: variant.stock,
      price: variant.price ?? ""
    })));
%>

<form
  method="POST"
  action="/admin/products/edit/<%= product.id %>?_csrf=<%= csrfToken %>"
  enctype="multipart/form-data"
  class="bg-white p-4 shadow rounded mb-4"
>
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">

  <h5 class="mb-3">Informacion basica</h5>

  <div class="mb-3">
    <label class="form-label">Nombre</label>
    <input
      name="name"
      class="form-control"
      value="<%= formData?.name ?? product.name %>"
      required
    >
  </div>

  <div class="mb-3">
    <label class="form-label">Descripcion corta</label>
    <textarea
      name="description"
      class="form-control"
      rows="2"
      required
    ><%= formData?.description ?? product.description %></textarea>
  </div>

  <div class="mb-4">
    <label class="form-label">Descripcion larga / especificaciones</label>
    <textarea
      name="longDescription"
      class="form-control"
      rows="6"
      placeholder="Ej: materiales, dimensiones, recomendaciones, uso..."
    ><%= formData?.longDescription ?? (product.longDescription || '') %></textarea>
  </div>

  <h5 class="mb-3">Inventario</h5>

  <div class="row">
    <div class="col-md-6 mb-3">
      <label class="form-label">Precio</label>
      <input
        name="price"
        type="number"
        min="0"
        step="0.01"
        class="form-control"
        value="<%= formData?.price ?? product.price %>"
        required
      >
    </div>

    <div class="col-12">
      <div class="border rounded p-3 mb-3 bg-light">
        <h5 class="mb-3">Descuento directo</h5>
        <div class="row g-3">
          <div class="col-md-3">
            <label class="form-label">Tipo</label>
            <select name="discountType" class="form-select">
              <% const discountType = formData?.discountType ?? product.discountType ?? 'none'; %>
              <option value="none" <%= discountType === 'none' ? 'selected' : '' %>>Sin descuento</option>
              <option value="percent" <%= discountType === 'percent' ? 'selected' : '' %>>Porcentaje</option>
              <option value="fixed" <%= discountType === 'fixed' ? 'selected' : '' %>>Valor fijo</option>
            </select>
          </div>
          <div class="col-md-3">
            <label class="form-label">Valor</label>
            <input
              name="discountValue"
              type="number"
              min="0"
              step="0.01"
              class="form-control"
              value="<%= formData?.discountValue ?? product.discountValue ?? 0 %>"
              placeholder="Ej: 20"
            >
            <div class="form-text">% o pesos segun el tipo.</div>
          </div>
          <div class="col-md-3">
            <label class="form-label">Inicio</label>
            <input type="date" name="discountStartDate" class="form-control" value="<%= formData?.discountStartDate ?? product.discountStartDate ?? '' %>">
          </div>
          <div class="col-md-3">
            <label class="form-label">Fin</label>
            <input type="date" name="discountEndDate" class="form-control" value="<%= formData?.discountEndDate ?? product.discountEndDate ?? '' %>">
          </div>
          <div class="col-12">
            <label class="form-label">Etiqueta opcional</label>
            <input
              name="discountLabel"
              class="form-control"
              value="<%= formData?.discountLabel ?? product.discountLabel ?? '' %>"
              placeholder="Ej: Liquidacion, Oferta de temporada"
            >
          </div>
        </div>
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <label class="form-label">Stock</label>
      <input
        name="stock"
        type="number"
        min="0"
        step="1"
        class="form-control"
        value="<%= formData?.stock ?? product.stock %>"
        required
      >
      <div class="form-text">
        Si el producto usa variantes, este valor se calcula automaticamente con su inventario.
      </div>
    </div>

    <div class="col-md-6 mb-3">
      <label class="form-label">Umbral de bajo stock</label>
      <input
        name="lowStockThreshold"
        type="number"
        min="0"
        step="1"
        class="form-control"
        value="<%= formData?.lowStockThreshold ?? product.lowStockThreshold %>"
        required
      >
    </div>
  </div>

  <div class="form-check form-switch mb-4">
    <input
      class="form-check-input"
      type="checkbox"
      id="isActive"
      name="isActive"
      <%= (formData?.isActive ?? product.isActive) ? "checked" : "" %>
    >
    <label class="form-check-label" for="isActive">Producto activo en tienda</label>
  </div>

  <div class="mb-4">
    <label class="form-label">Categoria</label>
    <select name="categoryId" class="form-control" required>
      <option value="">Selecciona una categoria</option>
      <% for (let i = 0; i < categories.length; i++) { %>
        <option
          value="<%= categories[i].id %>"
          <%= String(categories[i].id) === String(formData?.categoryId ?? product.CategoryId) ? "selected" : "" %>
        >
          <%= categories[i].name %>
        </option>
      <% } %>
    </select>
  </div>

  <h5 class="mb-3">Variantes</h5>

  <div class="mb-4">
    <div class="d-flex justify-content-between align-items-center mb-2">
      <p class="text-muted mb-0">Cada variante mantiene su propio stock y puede tener precio independiente.</p>
      <button type="button" class="btn btn-outline-primary btn-sm" onclick="addVariantRow()">
        Agregar variante
      </button>
    </div>

    <div class="table-responsive">
      <table class="table table-bordered align-middle mb-0">
        <thead class="table-light">
          <tr>
            <th>Nombre</th>
            <th style="width: 140px;">Stock</th>
            <th style="width: 140px;">Reservado</th>
            <th style="width: 180px;">Precio opcional</th>
            <th style="width: 80px;"></th>
          </tr>
        </thead>
        <tbody id="variantRows">
          <% currentVariants.forEach(variant => { %>
            <% const existingVariant = product.ProductVariants?.find(item => String(item.id) === String(variant.id || "")); %>
            <tr>
              <td>
                <input type="hidden" name="variantId" value="<%= variant.id || '' %>">
                <input type="text" name="variantName" class="form-control" value="<%= variant.name || '' %>" placeholder="Ej: 2 kg / Pollo / Azul">
              </td>
              <td>
                <input type="number" name="variantStock" min="0" step="1" class="form-control" value="<%= variant.stock ?? '' %>">
              </td>
              <td>
                <input type="number" class="form-control" value="<%= existingVariant?.reservedStock ?? 0 %>" disabled>
              </td>
              <td>
                <input type="number" name="variantPrice" min="0" step="0.01" class="form-control" value="<%= variant.price ?? '' %>" placeholder="Usa el precio base si lo dejas vacio">
              </td>
              <td class="text-center">
                <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeVariantRow(this)">X</button>
              </td>
            </tr>
          <% }) %>
        </tbody>
      </table>
    </div>
  </div>

  <h5 class="mb-3">Agregar nuevas imagenes</h5>

  <div class="mb-4">
    <label class="form-label">Nuevas imagenes</label>
    <input type="file" name="images" multiple class="form-control">
  </div>

  <button class="btn btn-warning w-100" type="submit">Actualizar Producto</button>
</form>

<div class="bg-white p-4 shadow rounded">
  <h5 class="mb-3">Imagenes actuales</h5>

  <div class="d-flex flex-wrap gap-3">
    <% if(product.ProductImages && product.ProductImages.length > 0){ %>
      <% for(let i = 0; i < product.ProductImages.length; i++){ const img = product.ProductImages[i]; %>
        <div style="position:relative;">
          <% if(img.isMain){ %>
            <span style="position:absolute; top:5px; left:5px; background:gold; padding:2px 6px; font-size:12px; border-radius:5px;">
              Principal
            </span>
          <% } %>

          <img
            src="/uploads/<%= img.image %>"
            width="110"
            style="border-radius:8px; object-fit:cover;"
          >

          <form
            method="POST"
            action="/admin/images/delete/<%= img.id %>"
            onsubmit="return confirm('Eliminar esta imagen?')"
            style="position:absolute; top:5px; right:5px; margin:0;"
          >
            <input type="hidden" name="_csrf" value="<%= csrfToken %>">
            <button
              type="submit"
              style="background:red; color:white; border-radius:50%; padding:2px 6px; font-size:12px; border:none;"
            >
              X
            </button>
          </form>

          <% if(!img.isMain){ %>
            <form
              method="POST"
              action="/admin/images/main/<%= img.id %>"
              style="position:absolute; bottom:5px; left:5px; margin:0;"
            >
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <button
                type="submit"
                style="background:#0d6efd; color:white; padding:2px 6px; font-size:12px; border-radius:5px; border:none;"
              >
                Principal
              </button>
            </form>
          <% } %>
        </div>
      <% } %>
    <% } else { %>
      <p class="text-muted mb-0">Sin imagenes</p>
    <% } %>
  </div>
</div>

<template id="variantRowTemplate">
  <tr>
    <td>
      <input type="hidden" name="variantId" value="">
      <input type="text" name="variantName" class="form-control" placeholder="Ej: 2 kg / Pollo / Azul">
    </td>
    <td>
      <input type="number" name="variantStock" min="0" step="1" class="form-control" value="0">
    </td>
    <td>
      <input type="number" class="form-control" value="0" disabled>
    </td>
    <td>
      <input type="number" name="variantPrice" min="0" step="0.01" class="form-control" placeholder="Usa el precio base si lo dejas vacio">
    </td>
    <td class="text-center">
      <button type="button" class="btn btn-outline-danger btn-sm" onclick="removeVariantRow(this)">X</button>
    </td>
  </tr>
</template>

<script>
  function addVariantRow() {
    const template = document.getElementById("variantRowTemplate");
    const container = document.getElementById("variantRows");
    container.appendChild(template.content.cloneNode(true));
  }

  function removeVariantRow(button) {
    button.closest("tr").remove();
  }
</script>
