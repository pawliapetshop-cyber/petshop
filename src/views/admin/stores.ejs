<%
  const visualPresets = [
    { key: "soft", label: "Brillo suave" },
    { key: "mesh", label: "Halo editorial" },
    { key: "none", label: "Plano limpio" }
  ];
  const groupedCategories = {};
  categories.forEach(category => {
    const key = String(category.StoreId || "global");
    groupedCategories[key] = groupedCategories[key] || [];
    groupedCategories[key].push(category);
  });
  const getStoreCategories = (storeId) => groupedCategories[String(storeId)] || [];
  const getSelectedIds = (values = []) => values.map(String);
  const creationCategories = formData?.storeId ? getStoreCategories(formData.storeId) : categories;
  const hasCreationErrors = Boolean(errorMessages && errorMessages.length > 0);
%>

<style>
  .stores-toolbar-card, .store-accordion .accordion-item { border: 0; border-radius: 24px; box-shadow: 0 16px 40px rgba(15, 23, 42, 0.08); overflow: hidden; }
  .store-accordion .accordion-button { background: linear-gradient(180deg, rgba(255,255,255,0.98), rgba(247,249,252,0.96)); box-shadow: none !important; padding: 1.25rem 1.5rem; }
  .store-accordion .accordion-button:not(.collapsed) { color: #1f2937; background: linear-gradient(180deg, #fff, rgba(240,244,248,0.98)); }
  .store-section-card { border: 1px solid #e9eef5; border-radius: 20px; padding: 1rem; background: linear-gradient(180deg, #fff 0%, #f8fafc 100%); height: 100%; }
  .store-section-card h6 { font-weight: 700; margin-bottom: .25rem; }
  .store-section-hint { color: #6b7280; font-size: .9rem; }
  .store-preview-chip { display: inline-flex; align-items: center; gap: .4rem; padding: .35rem .75rem; border-radius: 999px; font-size: .82rem; font-weight: 600; background: #eef2ff; color: #334155; }
  .store-preview-palette { width: 16px; height: 16px; border-radius: 50%; border: 2px solid rgba(255,255,255,.85); box-shadow: 0 0 0 1px rgba(15,23,42,.08); }
  .store-logo-preview { width: 72px; height: 72px; border-radius: 18px; object-fit: contain; background: #fff; border: 1px solid rgba(15,23,42,.08); padding: 6px; box-shadow: 0 12px 24px rgba(15,23,42,.08); }
  .store-empty-logo { width: 72px; height: 72px; border-radius: 18px; border: 1px dashed #cbd5e1; background: #f8fafc; color: #64748b; display: flex; align-items: center; justify-content: center; font-size: .85rem; }
  .store-promo-preview { max-height: 92px; object-fit: cover; border-radius: 16px; border: 1px solid rgba(15,23,42,.08); }
</style>

<h2 class="mb-4">Tiendas / Entidades</h2>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %>"><%= flash.message %></div>
<% } %>

<% if (errorMessages && errorMessages.length > 0) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errorMessages.forEach(message => { %>
        <li><%= message %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<div class="stores-toolbar-card bg-white p-4 mb-4">
  <div class="d-flex flex-wrap justify-content-between align-items-center gap-3">
    <div>
      <h4 class="mb-1">Centro de tiendas</h4>
      <p class="text-muted mb-0">Gestiona marca, apariencia y bloques comerciales por entidad sin tocar pedidos ni inventario.</p>
    </div>
    <div class="d-flex flex-wrap gap-2">
      <span class="store-preview-chip"><%= stores.length %> tiendas registradas</span>
      <span class="store-preview-chip"><%= stores.filter(store => store.isActive).length %> activas</span>
      <span class="store-preview-chip"><%= stores.filter(store => !store.isActive).length %> inactivas</span>
    </div>
  </div>
</div>

<div class="accordion store-accordion mb-4" id="storeManagementAccordion">
  <div class="accordion-item mb-4">
    <h2 class="accordion-header" id="headingCreateStore">
      <button class="accordion-button <%= hasCreationErrors ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#collapseCreateStore" aria-expanded="<%= hasCreationErrors ? 'true' : 'false' %>">
        <div class="w-100 d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <span class="d-block fw-semibold">Crear nueva tienda</span>
            <small class="text-muted">Identidad, branding y bloques de portada en un solo flujo.</small>
          </div>
          <span class="badge text-bg-success">Nueva entidad</span>
        </div>
      </button>
    </h2>
    <div id="collapseCreateStore" class="accordion-collapse collapse <%= hasCreationErrors ? 'show' : '' %>" data-bs-parent="#storeManagementAccordion">
      <div class="accordion-body">
        <form method="POST" action="/admin/stores/create?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="row g-4">
          <%- include("stores/_storeFields", { storeData: formData, csrfToken, categories: creationCategories, visualPresets, mode: "create" }) %>
          <div class="col-12 d-flex justify-content-end">
            <button class="btn btn-success" type="submit">Crear tienda</button>
          </div>
        </form>
      </div>
    </div>
  </div>

  <div class="accordion-item">
    <h2 class="accordion-header" id="headingExistingStores">
      <button class="accordion-button collapsed" type="button" data-bs-toggle="collapse" data-bs-target="#collapseExistingStores" aria-expanded="false">
        <div class="w-100 d-flex flex-wrap justify-content-between align-items-center gap-2">
          <div>
            <span class="d-block fw-semibold">Tiendas registradas</span>
            <small class="text-muted">Cada tienda se edita dentro de su propio bloque plegable.</small>
          </div>
          <span class="badge text-bg-secondary"><%= stores.length %> registros</span>
        </div>
      </button>
    </h2>
    <div id="collapseExistingStores" class="accordion-collapse collapse show" data-bs-parent="#storeManagementAccordion">
      <div class="accordion-body">
        <% if (stores.length === 0) { %>
          <p class="text-muted mb-0">Todavia no hay tiendas registradas.</p>
        <% } %>

        <div class="accordion store-accordion" id="existingStoresAccordion">
          <% stores.forEach((store, index) => { %>
            <% const decorMode = store.themeConfig?.backgroundDecorMode || "soft"; %>
            <div class="accordion-item mb-3">
              <h2 class="accordion-header" id="storeHeading-<%= store.id %>">
                <button class="accordion-button <%= index === 0 ? '' : 'collapsed' %>" type="button" data-bs-toggle="collapse" data-bs-target="#storeCollapse-<%= store.id %>" aria-expanded="<%= index === 0 ? 'true' : 'false' %>">
                  <div class="w-100 d-flex flex-wrap justify-content-between align-items-center gap-3">
                    <div class="d-flex align-items-center gap-3">
                      <% if (store.logo) { %>
                        <img src="/uploads/<%= store.logo %>" alt="<%= store.name %>" class="store-logo-preview">
                      <% } else { %>
                        <div class="store-empty-logo">Sin logo</div>
                      <% } %>
                      <div>
                        <div class="fw-semibold"><%= store.name %></div>
                        <div class="text-muted small">/s/<%= store.slug %></div>
                      </div>
                    </div>
                    <div class="d-flex flex-wrap gap-2">
                      <span class="store-preview-chip"><span class="store-preview-palette" style="background:<%= store.primaryColor || '#198754' %>;"></span> Primario</span>
                      <span class="store-preview-chip"><span class="store-preview-palette" style="background:<%= store.themeConfig?.backgroundColor || '#f5f5f5' %>;"></span> Fondo</span>
                      <span class="store-preview-chip"><%= decorMode === "mesh" ? "Editorial" : decorMode === "none" ? "Plano" : "Suave" %></span>
                      <span class="badge <%= store.isActive ? 'text-bg-success' : 'text-bg-secondary' %>"><%= store.isActive ? 'Activa' : 'Inactiva' %></span>
                    </div>
                  </div>
                </button>
              </h2>
              <div id="storeCollapse-<%= store.id %>" class="accordion-collapse collapse <%= index === 0 ? 'show' : '' %>" data-bs-parent="#existingStoresAccordion">
                <div class="accordion-body">
                  <form method="POST" action="/admin/stores/<%= store.id %>/update?_csrf=<%= csrfToken %>" enctype="multipart/form-data" class="row g-4">
                    <%- include("stores/_storeFields", { storeData: store, csrfToken, categories: getStoreCategories(store.id), visualPresets, mode: "update" }) %>
                    <div class="col-12 d-flex flex-wrap justify-content-end gap-2">
                      <a href="/admin/shipping-settings?storeId=<%= store.id %>" class="btn btn-outline-secondary">Configurar envios</a>
                      <button class="btn btn-primary" type="submit">Guardar cambios</button>
                    </div>
                  </form>
                </div>
              </div>
            </div>
          <% }) %>
        </div>
      </div>
    </div>
  </div>
</div>

<script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
