<div class="d-flex justify-content-between align-items-center mb-4">
  <div>
    <h2 class="mb-1">Configuracion de envios</h2>
    <small class="text-muted">
      Ajusta si se cobra o no el envio por ciudad para <strong><%= selectedStore.name %></strong>.
    </small>
  </div>
</div>

<% if (flash) { %>
  <div class="alert alert-<%= flash.type === 'success' ? 'success' : 'danger' %>">
    <%= flash.message %>
  </div>
<% } %>

<% if (errorMessages && errorMessages.length > 0) { %>
  <div class="alert alert-danger">
    <ul class="mb-0">
      <% errorMessages.forEach(message => { %>
        <li><%= message %></li>
      <% }) %>
    </ul>
  </div>
<% } %>

<% if (adminSession?.role === "superadmin") { %>
  <div class="bg-white shadow rounded p-3 mb-4">
    <form method="GET" action="/admin/shipping-settings" class="row g-3 align-items-end">
      <div class="col-md-4">
        <label class="form-label">Tienda</label>
        <select name="storeId" class="form-select" onchange="this.form.submit()">
          <% stores.forEach(store => { %>
            <option value="<%= store.id %>" <%= Number(selectedStore.id) === Number(store.id) ? "selected" : "" %>>
              <%= store.name %> (<%= store.slug %>)
            </option>
          <% }) %>
        </select>
      </div>
      <div class="col-md-4">
        <small class="text-muted d-block">URL publica</small>
        <a href="/s/<%= selectedStore.slug %>" target="_blank">/s/<%= selectedStore.slug %></a>
      </div>
    </form>
  </div>
<% } %>

<form method="POST" action="/admin/shipping-settings" class="bg-white shadow rounded p-4">
  <input type="hidden" name="_csrf" value="<%= csrfToken %>">
  <input type="hidden" name="storeId" value="<%= selectedStore.id %>">

  <div class="table-responsive">
    <table class="table align-middle">
      <thead>
        <tr>
          <th>Ciudad</th>
          <th>Cobrar envio</th>
          <th>Costo</th>
          <th>Contraentrega</th>
        </tr>
      </thead>
      <tbody>
        <% shippingCities.forEach(city => { %>
          <tr>
            <td>
              <strong><%= city.label %></strong>
            </td>
            <td>
              <div class="form-check form-switch">
                <input
                  class="form-check-input shipping-toggle"
                  type="checkbox"
                  id="charge-<%= city.key %>"
                  name="chargeShipping_<%= city.key %>"
                  data-target="cost-<%= city.key %>"
                  <%= city.chargeShipping ? "checked" : "" %>
                >
                <label class="form-check-label" for="charge-<%= city.key %>">
                  <%= city.chargeShipping ? "Si" : "No" %>
                </label>
              </div>
            </td>
            <td style="max-width: 180px;">
              <input
                type="number"
                min="0"
                step="100"
                class="form-control"
                id="cost-<%= city.key %>"
                name="shippingCost_<%= city.key %>"
                value="<%= Number(city.cost || 0) %>"
                <%= city.chargeShipping ? "" : "disabled" %>
              >
            </td>
            <td>
              <div class="form-check form-switch">
                <input
                  class="form-check-input"
                  type="checkbox"
                  id="contra-<%= city.key %>"
                  name="allowCashOnDelivery_<%= city.key %>"
                  <%= city.allowCashOnDelivery ? "checked" : "" %>
                >
                <label class="form-check-label" for="contra-<%= city.key %>">
                  <%= city.allowCashOnDelivery ? "Si" : "No" %>
                </label>
              </div>
            </td>
          </tr>
        <% }) %>
      </tbody>
    </table>
  </div>

  <div class="d-flex justify-content-between align-items-center mt-3">
    <small class="text-muted">
      Si desactivas el cobro de una ciudad, el checkout mostrara envio gratis para esa ubicacion.
    </small>
    <button class="btn btn-success" type="submit">Guardar configuracion</button>
  </div>
</form>

<script>
  document.querySelectorAll(".shipping-toggle").forEach((toggle) => {
    const target = document.getElementById(toggle.dataset.target);
    const label = toggle.closest(".form-check")?.querySelector(".form-check-label");

    const sync = () => {
      target.disabled = !toggle.checked;
      if (!toggle.checked) {
        target.value = 0;
      }
      if (label) {
        label.textContent = toggle.checked ? "Si" : "No";
      }
    };

    toggle.addEventListener("change", sync);
    sync();
  });

  document.querySelectorAll('input[id^="contra-"]').forEach((toggle) => {
    const label = toggle.closest(".form-check")?.querySelector(".form-check-label");
    const sync = () => {
      if (label) {
        label.textContent = toggle.checked ? "Si" : "No";
      }
    };
    toggle.addEventListener("change", sync);
    sync();
  });
</script>
