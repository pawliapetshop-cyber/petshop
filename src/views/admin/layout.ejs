<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%
    const adminPrimaryColor = adminSession?.primaryColor || "#198754";
    const adminSecondaryColor = adminSession?.secondaryColor || "#212529";
    const adminStoreLogo = adminSession?.storeLogo ? `/uploads/${adminSession.storeLogo}` : "/logo.jpeg";
  %>
  <title>Admin - <%= adminSession?.storeName || "Pawlia" %></title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --admin-primary: <%= adminPrimaryColor %>;
      --admin-secondary: <%= adminSecondaryColor %>;
      --admin-primary-soft: color-mix(in srgb, <%= adminPrimaryColor %> 14%, white);
    }

    body {
      background:
        radial-gradient(circle at top right, var(--admin-primary-soft), transparent 30%),
        #f4f6f9;
      overflow-x: hidden;
    }

    .sidebar {
      background: linear-gradient(180deg, var(--admin-secondary), color-mix(in srgb, var(--admin-secondary) 78%, black));
      color: white;
      padding: 20px;
      position: fixed;
      top: 0;
      left: 0;
      bottom: 0;
      width: 220px;
      height: 100vh;
      overflow-y: auto;
      z-index: 1045;
      box-shadow: 18px 0 42px rgba(15, 23, 42, 0.18);
      transition: transform 180ms ease, box-shadow 180ms ease;
    }

    .sidebar a {
      color: #adb5bd;
      display: block;
      padding: 10px;
      text-decoration: none;
      border-radius: 10px;
    }

    .sidebar a:hover {
      background: color-mix(in srgb, var(--admin-primary) 22%, white);
      color: white;
    }

    .content {
      margin-left: 240px;
      padding: 20px;
    }

    .admin-mobile-bar,
    .admin-sidebar-backdrop {
      display: none;
    }

    .admin-logo {
      width: 56px;
      height: 56px;
      object-fit: contain;
      background: white;
      border-radius: 14px;
      padding: 6px;
      border: 1px solid rgba(255, 255, 255, 0.18);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.16);
    }

    @media (max-width: 991.98px) {
      body.admin-sidebar-open {
        overflow: hidden;
      }

      .admin-mobile-bar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: 12px;
        position: sticky;
        top: 0;
        z-index: 1040;
        padding: 12px 16px;
        background: rgba(255, 255, 255, 0.95);
        backdrop-filter: blur(10px);
        border-bottom: 1px solid rgba(15, 23, 42, 0.08);
      }

      .admin-mobile-toggle {
        border: 0;
        border-radius: 14px;
        background: var(--admin-secondary);
        color: white;
        width: 44px;
        height: 44px;
        font-size: 1.2rem;
        line-height: 1;
        box-shadow: 0 12px 26px rgba(15, 23, 42, 0.18);
      }

      .admin-mobile-store {
        min-width: 0;
      }

      .admin-mobile-store strong,
      .admin-mobile-store small {
        display: block;
        overflow: hidden;
        text-overflow: ellipsis;
        white-space: nowrap;
      }

      .admin-sidebar-backdrop {
        display: block;
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.42);
        opacity: 0;
        pointer-events: none;
        transition: opacity 180ms ease;
        z-index: 1040;
      }

      body.admin-sidebar-open .admin-sidebar-backdrop {
        opacity: 1;
        pointer-events: auto;
      }

      .sidebar {
        width: min(280px, calc(100vw - 40px));
        transform: translateX(-105%);
        border-radius: 0 26px 26px 0;
      }

      body.admin-sidebar-open .sidebar {
        transform: translateX(0);
      }

      .content {
        margin-left: 0;
        padding: 16px;
      }
    }
  </style>
</head>

<body>

<div class="admin-mobile-bar d-lg-none">
  <div class="d-flex align-items-center gap-3 min-w-0">
    <button type="button" class="admin-mobile-toggle" data-admin-sidebar-toggle aria-label="Abrir menu">
      ☰
    </button>
    <div class="admin-mobile-store">
      <strong><%= adminSession?.storeName || "Pawlia" %></strong>
      <small class="text-muted"><%= adminSession?.role === "superadmin" ? "Superadmin" : "Admin de tienda" %></small>
    </div>
  </div>
  <a href="<%= adminSession?.storeSlug ? `/s/${adminSession.storeSlug}` : '/tienda' %>" class="btn btn-outline-secondary btn-sm">Ver tienda</a>
</div>

<div class="admin-sidebar-backdrop" data-admin-sidebar-close></div>

<aside class="sidebar">
  <div class="d-flex align-items-center gap-3 mb-2">
    <img src="<%= adminStoreLogo %>" alt="<%= adminSession?.storeName || 'Pawlia' %>" class="admin-logo">
    <div>
      <h4 class="mb-0"><%= adminSession?.storeName || "Pawlia" %></h4>
      <small class="text-white-50">Admin panel</small>
    </div>
  </div>
  <% if (adminSession?.storeName) { %>
    <small class="text-white-50 d-block mb-2"><%= adminSession.storeName %></small>
  <% } %>
  <% if (adminSession?.role) { %>
    <small class="text-white-50 d-block"><%= adminSession.role === "superadmin" ? "Superadmin" : "Admin de tienda" %></small>
  <% } %>
  <hr>

  <a href="/admin">Dashboard</a>
  <% if (adminSession?.role === "superadmin") { %>
    <a href="/admin/stores">Tiendas</a>
    <a href="/admin/admin-users">Admins</a>
  <% } %>
  <a href="/admin/banners">Banners</a>
  <a href="/admin/side-ads">Publicidad lateral</a>
  <a href="/admin/coupons">Cupones</a>
  <a href="/admin/shipping-settings">Envios</a>
  <a href="/admin/notifications">Notificaciones</a>
  <a href="/admin/reviews">Resenas</a>
  <a href="/admin/reports">Reportes</a>
  <a href="/admin/customers">Clientes</a>
  <a href="/admin/products">Productos</a>
  <a href="/admin/orders">Ver pedidos</a>
  <a href="/admin/categories">Categorias</a>
  <a href="<%= adminSession?.storeSlug ? `/s/${adminSession.storeSlug}` : '/tienda' %>">Ver tienda</a>

  <hr>
  <a href="/logout" class="text-danger">Cerrar sesion</a>
</aside>

<div class="content">
  <%- body %>
</div>

<script>
  (() => {
    const body = document.body;
    const toggle = document.querySelector("[data-admin-sidebar-toggle]");
    const backdrop = document.querySelector("[data-admin-sidebar-close]");
    const sidebarLinks = document.querySelectorAll(".sidebar a");
    const desktopQuery = window.matchMedia("(min-width: 992px)");

    const closeSidebar = () => body.classList.remove("admin-sidebar-open");
    const toggleSidebar = () => body.classList.toggle("admin-sidebar-open");

    toggle?.addEventListener("click", toggleSidebar);
    backdrop?.addEventListener("click", closeSidebar);

    sidebarLinks.forEach(link => {
      link.addEventListener("click", () => {
        if (!desktopQuery.matches) {
          closeSidebar();
        }
      });
    });

    document.addEventListener("keydown", event => {
      if (event.key === "Escape") {
        closeSidebar();
      }
    });

    desktopQuery.addEventListener("change", event => {
      if (event.matches) {
        closeSidebar();
      }
    });
  })();
</script>

</body>
</html>
