<style>
  .product-shell {
    gap: 1.5rem;
  }

  .product-card,
  .product-block {
    background: white;
    border-radius: 24px;
    box-shadow: 0 18px 40px rgba(15, 23, 42, 0.08);
  }

  .product-card {
    padding: 1.5rem;
  }

  .product-block {
    padding: 1.75rem;
  }

  .product-gallery-panel {
    background: linear-gradient(180deg, rgba(248,250,252,0.98), rgba(255,255,255,0.98));
    border-radius: 24px;
    padding: 1rem;
    border: 1px solid rgba(15, 23, 42, 0.06);
  }

  .product-stage {
    position: relative;
    border-radius: 24px;
    overflow: hidden;
    background: linear-gradient(180deg, rgba(255,255,255,0.95), rgba(243,246,249,0.95));
    min-height: 440px;
    display: flex;
    align-items: center;
    justify-content: center;
    cursor: zoom-in;
  }

  .product-stage img {
    width: 100%;
    max-height: 440px;
    object-fit: contain;
    display: none;
    padding: 1rem;
  }

  .product-stage img.is-active {
    display: block;
  }

  .product-stage-control {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    width: 44px;
    height: 44px;
    border: 0;
    border-radius: 999px;
    background: rgba(15, 23, 42, 0.68);
    color: white;
    font-size: 1.4rem;
    line-height: 1;
    z-index: 2;
  }

  .product-stage-control--prev {
    left: 14px;
  }

  .product-stage-control--next {
    right: 14px;
  }

  .product-thumb-strip {
    display: flex;
    gap: 0.75rem;
    margin-top: 1rem;
    overflow-x: auto;
    padding-bottom: 0.25rem;
  }

  .product-thumb {
    width: 86px;
    height: 86px;
    border-radius: 20px;
    overflow: hidden;
    border: 2px solid transparent;
    background: #f8fafc;
    padding: 0;
    flex: 0 0 auto;
    cursor: pointer;
  }

  .product-thumb img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .product-thumb.is-active {
    border-color: #198754;
    box-shadow: 0 10px 24px rgba(25, 135, 84, 0.18);
  }

  .product-gallery-meta {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: 1rem;
    margin-top: 0.85rem;
  }

  .product-gallery-counter {
    color: #64748b;
    font-size: 0.92rem;
  }

  .product-gallery-hint {
    color: #64748b;
    font-size: 0.85rem;
  }

  .product-lightbox,
  .review-image-modal {
    position: fixed;
    inset: 0;
    background: rgba(0, 0, 0, 0.78);
    display: none;
    align-items: center;
    justify-content: center;
    padding: 24px;
    z-index: 1050;
    backdrop-filter: blur(6px);
  }

  .product-lightbox.is-open,
  .review-image-modal.is-open {
    display: flex;
  }

  .product-lightbox__dialog,
  .review-image-modal__dialog {
    position: relative;
    max-width: min(1100px, 100%);
    max-height: 90vh;
  }

  .product-lightbox__image,
  .review-image-modal__image {
    max-width: 100%;
    max-height: 82vh;
    border-radius: 20px;
    display: block;
    box-shadow: 0 20px 60px rgba(0, 0, 0, 0.35);
    background: white;
  }

  .product-lightbox__close,
  .review-image-modal__close {
    position: absolute;
    top: -14px;
    right: -14px;
    border: 0;
    background: #fff;
    color: #111;
    width: 40px;
    height: 40px;
    border-radius: 999px;
    font-size: 22px;
    line-height: 1;
    cursor: pointer;
    box-shadow: 0 10px 30px rgba(0, 0, 0, 0.22);
  }

  .review-image-thumb {
    width: 88px;
    height: 88px;
    object-fit: cover;
    border-radius: 12px;
    cursor: pointer;
    transition: transform 0.18s ease;
  }

  .review-image-thumb:hover {
    transform: scale(1.03);
  }

  @media (max-width: 991.98px) {
    .product-stage {
      min-height: 320px;
    }

    .product-stage img {
      max-height: 320px;
    }
  }
</style>

<div class="container mt-5">
  <% if (errorMessage) { %>
    <div class="alert alert-danger"><%= errorMessage %></div>
  <% } %>

  <% if (successMessage) { %>
    <div class="alert alert-success"><%= successMessage %></div>
  <% } %>

  <%
    const available = Number(product.inventorySummary?.available) || 0;
    const variants = product.inventorySummary?.variants || [];
    const hasVariants = Boolean(product.inventorySummary?.hasVariants);
    const images = product.ProductImages || [];
    const main = images.find(i => i.isMain) || images[0];
  %>

  <div class="row product-shell mb-4">
    <div class="col-12">
      <div class="product-card">
        <div class="row g-4 align-items-start">
          <div class="col-lg-6">
            <div class="product-gallery-panel">
              <div class="product-stage" id="productStage" onclick="openProductLightbox()">
                <% images.forEach((img, index) => { %>
                  <img
                    src="/uploads/<%= img.image %>"
                    alt="<%= product.name %>"
                    class="<%= index === 0 || img.id === main?.id ? 'is-active' : '' %>"
                    data-gallery-image
                  >
                <% }) %>

                <% if (images.length > 1) { %>
                  <button type="button" class="product-stage-control product-stage-control--prev" onclick="event.stopPropagation(); changeGallerySlide(-1);" aria-label="Imagen anterior">
                    &#8249;
                  </button>
                  <button type="button" class="product-stage-control product-stage-control--next" onclick="event.stopPropagation(); changeGallerySlide(1);" aria-label="Imagen siguiente">
                    &#8250;
                  </button>
                <% } %>
              </div>

              <% if (images.length > 0) { %>
                <div class="product-gallery-meta">
                  <div class="product-gallery-counter">
                    <span id="galleryCounter"><%= images.length > 1 ? `1 / ${images.length}` : `1 imagen` %></span>
                  </div>
                  <div class="product-gallery-hint">Haz clic sobre la imagen para verla en grande.</div>
                </div>
              <% } %>

              <% if (images.length > 1) { %>
                <div class="product-thumb-strip">
                  <% images.forEach((img, index) => { %>
                    <button
                      type="button"
                      class="product-thumb <%= index === 0 || img.id === main?.id ? 'is-active' : '' %>"
                      onclick="setGallerySlide(<%= index %>)"
                      data-gallery-thumb
                      aria-label="Ver imagen <%= index + 1 %>"
                    >
                      <img src="/uploads/<%= img.image %>" alt="<%= product.name %>">
                    </button>
                  <% }) %>
                </div>
              <% } %>
            </div>
          </div>

          <div class="col-lg-6">
            <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
              <div>
                <small class="text-uppercase text-muted"><%= product.Category?.name %></small>
                <h3 class="mt-1"><%= product.name %></h3>
              </div>
              <a href="<%= storeBasePath %>" class="btn btn-outline-secondary btn-sm">Volver</a>
            </div>

            <h2 class="text-success">
              <% if (product.pricingSummary?.hasPriceRange) { %>
                Desde $<%= Number(product.pricingSummary.effectiveMinPrice).toLocaleString() %>
              <% } else { %>
                $<%= Number(product.price).toLocaleString() %>
              <% } %>
            </h2>

            <% if (product.pricingSummary?.hasPriceRange) { %>
              <p class="text-muted mb-2">
                Rango hasta $<%= Number(product.pricingSummary.effectiveMaxPrice).toLocaleString() %> segun la variante.
              </p>
            <% } %>

            <p class="mt-3"><%= product.description %></p>

            <div class="d-flex align-items-center gap-2 mb-3">
              <span class="text-warning fs-5">&#9733;</span>
              <strong><%= product.reviewSummary?.averageLabel || "0.0" %></strong>
              <small class="text-muted">(<%= product.reviewSummary?.count || 0 %> resenas aprobadas)</small>
            </div>

            <p>
              <strong>Disponibilidad:</strong>
              <% if (available > 0) { %>
                <span class="text-success"><%= available %> disponibles</span>
              <% } else { %>
                <span class="text-danger">Sin stock</span>
              <% } %>
            </p>

            <% if (hasVariants) { %>
              <p class="text-muted small">
                Este producto se vende por opciones. Elige la presentacion adecuada antes de agregarlo al carrito.
              </p>
            <% } %>

            <% if (available > 0) { %>
              <form method="POST" action="<%= `${storeBasePath}/cart/add` %>">
                <input type="hidden" name="_csrf" value="<%= csrfToken %>">
                <input type="hidden" name="productId" value="<%= product.id %>">

                <% if (hasVariants) { %>
                  <div class="mb-3">
                    <label class="form-label"><strong>Variante</strong></label>
                    <select name="variantId" class="form-select" required>
                      <option value="">Selecciona una opcion</option>
                      <% variants.forEach(variant => { %>
                        <option
                          value="<%= variant.id %>"
                          <%= String(selectedVariantId || "") === String(variant.id) ? "selected" : "" %>
                          <%= variant.available <= 0 ? "disabled" : "" %>
                        >
                          <%= variant.name %>
                          <% if (variant.price !== null && variant.price !== undefined) { %>
                            - $<%= Number(variant.price).toLocaleString() %>
                          <% } %>
                          - <%= variant.available > 0 ? `${variant.available} disponibles` : "Sin stock" %>
                        </option>
                      <% }) %>
                    </select>
                    <div class="form-text">
                      El precio y la disponibilidad cambian segun la opcion seleccionada.
                    </div>
                  </div>
                <% } %>

                <button class="btn btn-success w-100">
                  <%= hasVariants ? "Agregar variante al carrito" : "Agregar al carrito" %>
                </button>
              </form>
            <% } else { %>
              <button class="btn btn-secondary w-100" disabled>
                Sin stock
              </button>
            <% } %>
          </div>
        </div>
      </div>
    </div>
  </div>

  <div class="product-block mb-4">
    <h4>Descripcion del producto</h4>
    <hr>
    <p style="white-space: pre-line;">
      <%= product.longDescription || "Sin informacion adicional" %>
    </p>
  </div>

  <div class="product-block mb-4">
    <div class="d-flex justify-content-between align-items-center mb-3">
      <div>
        <h4 class="mb-0">Resenas y calificaciones</h4>
        <small class="text-muted">Solo compradores verificados pueden calificar este producto.</small>
      </div>
      <div class="text-end">
        <div class="fw-semibold"><%= product.reviewSummary?.averageLabel || "0.0" %> / 5</div>
        <small class="text-muted"><%= product.reviewSummary?.count || 0 %> aprobadas</small>
      </div>
    </div>

    <% if (product.Reviews && product.Reviews.length > 0) { %>
      <div class="row g-3 mb-4">
        <% product.Reviews.forEach(review => { %>
          <div class="col-12">
            <div class="border rounded p-3">
              <div class="d-flex justify-content-between align-items-start gap-3 mb-2">
                <div>
                  <strong><%= review.customerName %></strong>
                  <div class="text-warning">
                    <%= "★".repeat(Math.round(Number(review.rating) || 0)) %>
                    <span class="text-dark ms-1"><%= Number(review.rating).toFixed(1) %></span>
                  </div>
                </div>
                <small class="text-muted"><%= new Date(review.createdAt).toLocaleDateString("es-CO") %></small>
              </div>

              <p class="mb-2"><%= review.comment %></p>

              <% if (review.ReviewImages && review.ReviewImages.length > 0) { %>
                <div class="d-flex flex-wrap gap-2">
                  <% review.ReviewImages.forEach(image => { %>
                    <img
                      src="/uploads/<%= image.image %>"
                      alt="Resena de <%= review.customerName %>"
                      class="review-image-thumb"
                      onclick="openReviewImageModal(this.src, this.alt)"
                    >
                  <% }) %>
                </div>
                <small class="text-muted d-block mt-2">Haz clic en una foto para verla en grande.</small>
              <% } %>
            </div>
          </div>
        <% }) %>
      </div>
    <% } else { %>
      <p class="text-muted">Todavia no hay resenas aprobadas para este producto.</p>
    <% } %>

    <% if (reviewErrors && reviewErrors.length > 0) { %>
      <div class="alert alert-danger">
        <ul class="mb-0">
          <% reviewErrors.forEach(message => { %>
            <li><%= message %></li>
          <% }) %>
        </ul>
      </div>
    <% } %>

    <form method="POST" action="<%= `${storeBasePath}/producto/${product.id}/reviews?_csrf=${csrfToken}` %>" enctype="multipart/form-data" class="row g-3">
      <div class="col-md-4">
        <label class="form-label">Nombre</label>
        <input type="text" name="customerName" class="form-control" value="<%= reviewFormData?.customerName || '' %>" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">Correo de compra</label>
        <input type="email" name="customerEmail" class="form-control" value="<%= reviewFormData?.customerEmail || '' %>" required>
      </div>

      <div class="col-md-4">
        <label class="form-label">Calificacion</label>
        <input type="number" name="rating" min="0.5" max="5" step="0.5" class="form-control" value="<%= reviewFormData?.rating || '' %>" required>
      </div>

      <div class="col-12">
        <label class="form-label">Comentario</label>
        <textarea name="comment" rows="4" class="form-control" required><%= reviewFormData?.comment || '' %></textarea>
      </div>

      <div class="col-12">
        <label class="form-label">Fotos opcionales</label>
        <input type="file" name="reviewImages" class="form-control" accept="image/*" multiple>
        <div class="form-text">Puedes subir hasta 3 fotos. La resena quedara pendiente de aprobacion antes de publicarse.</div>
      </div>

      <div class="col-12">
        <button class="btn btn-success" type="submit">Enviar resena</button>
      </div>
    </form>
  </div>

  <% if (hasVariants) { %>
    <div class="product-block mb-4">
      <h4>Opciones disponibles</h4>
      <hr>

      <div class="row g-3">
        <% variants.forEach(variant => { %>
          <div class="col-md-4">
            <div class="border rounded p-3 h-100">
              <strong><%= variant.name %></strong>
              <div class="text-success mt-2">
                $<%= Number(variant.price ?? product.price).toLocaleString() %>
              </div>
              <small class="<%= variant.available > 0 ? 'text-muted' : 'text-danger' %>">
                <%= variant.available > 0 ? `${variant.available} disponibles` : "Sin stock" %>
              </small>
            </div>
          </div>
        <% }) %>
      </div>
    </div>
  <% } %>

  <div class="product-block">
    <h4>Productos relacionados</h4>
    <hr>

    <div class="row">
      <% relatedProducts.forEach(r => { %>
        <div class="col-md-3 mb-3">
          <%
            const img = r.ProductImages?.find(i => i.isMain) || r.ProductImages?.[0];
            const availableR = Number(r.inventorySummary?.available) || 0;
          %>

          <div class="card h-100 position-relative">
            <% if (availableR <= 0) { %>
              <span style="position:absolute; top:10px; left:10px; background:red; color:white; padding:3px 8px; font-size:12px; border-radius:5px; z-index:10;">
                Sin stock
              </span>
            <% } %>

            <% if (img) { %>
              <img
                src="/uploads/<%= img.image %>"
                class="card-img-top"
                style="height:150px; object-fit:cover; opacity:<%= availableR <= 0 ? 0.5 : 1 %>;"
                alt="<%= r.name %>"
              >
            <% } %>

            <div class="card-body text-center">
              <small><%= r.name %></small>
              <h6 class="text-success mt-2">
                <% if (r.pricingSummary?.hasPriceRange) { %>
                  Desde $<%= Number(r.pricingSummary.effectiveMinPrice).toLocaleString() %>
                <% } else { %>
                  $<%= Number(r.price).toLocaleString() %>
                <% } %>
              </h6>

              <% if (availableR > 0) { %>
                <a href="<%= `${storeBasePath}/producto/${r.id}` %>" class="btn btn-sm btn-success w-100">
                  Ver producto
                </a>
              <% } else { %>
                <button class="btn btn-sm btn-secondary w-100" disabled>
                  Sin stock
                </button>
              <% } %>
            </div>
          </div>
        </div>
      <% }) %>
    </div>
  </div>
</div>

<div id="productLightbox" class="product-lightbox" onclick="handleProductLightboxBackdrop(event)">
  <div class="product-lightbox__dialog">
    <button type="button" class="product-lightbox__close" onclick="closeProductLightbox()" aria-label="Cerrar imagen">
      &times;
    </button>
    <img id="productLightboxImg" src="" alt="" class="product-lightbox__image">
  </div>
</div>

<div id="reviewImageModal" class="review-image-modal" onclick="handleReviewModalBackdrop(event)">
  <div class="review-image-modal__dialog">
    <button type="button" class="review-image-modal__close" onclick="closeReviewImageModal()" aria-label="Cerrar imagen">
      &times;
    </button>
    <img id="reviewImageModalImg" src="" alt="" class="review-image-modal__image">
  </div>
</div>

<script>
  const galleryImages = Array.from(document.querySelectorAll("[data-gallery-image]"));
  const galleryThumbs = Array.from(document.querySelectorAll("[data-gallery-thumb]"));
  const galleryCounter = document.getElementById("galleryCounter");
  let currentGalleryIndex = Math.max(galleryImages.findIndex(image => image.classList.contains("is-active")), 0);

  function renderGallery() {
    if (galleryImages.length === 0) {
      return;
    }

    galleryImages.forEach((image, index) => {
      image.classList.toggle("is-active", index === currentGalleryIndex);
    });

    galleryThumbs.forEach((thumb, index) => {
      thumb.classList.toggle("is-active", index === currentGalleryIndex);
    });

    if (galleryCounter) {
      galleryCounter.textContent = galleryImages.length > 1
        ? `${currentGalleryIndex + 1} / ${galleryImages.length}`
        : "1 imagen";
    }
  }

  function setGallerySlide(index) {
    if (galleryImages.length === 0) {
      return;
    }
    currentGalleryIndex = (index + galleryImages.length) % galleryImages.length;
    renderGallery();
  }

  function changeGallerySlide(direction) {
    setGallerySlide(currentGalleryIndex + direction);
  }

  function openProductLightbox() {
    if (galleryImages.length === 0) {
      return;
    }

    const modal = document.getElementById("productLightbox");
    const image = document.getElementById("productLightboxImg");
    image.src = galleryImages[currentGalleryIndex].src;
    image.alt = galleryImages[currentGalleryIndex].alt || "<%= product.name %>";
    modal.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeProductLightbox() {
    const modal = document.getElementById("productLightbox");
    const image = document.getElementById("productLightboxImg");
    modal.classList.remove("is-open");
    image.src = "";
    document.body.style.overflow = "";
  }

  function handleProductLightboxBackdrop(event) {
    if (event.target.id === "productLightbox") {
      closeProductLightbox();
    }
  }

  function openReviewImageModal(src, alt) {
    const modal = document.getElementById("reviewImageModal");
    const image = document.getElementById("reviewImageModalImg");
    image.src = src;
    image.alt = alt || "Imagen de resena";
    modal.classList.add("is-open");
    document.body.style.overflow = "hidden";
  }

  function closeReviewImageModal() {
    const modal = document.getElementById("reviewImageModal");
    const image = document.getElementById("reviewImageModalImg");
    modal.classList.remove("is-open");
    image.src = "";
    document.body.style.overflow = "";
  }

  function handleReviewModalBackdrop(event) {
    if (event.target.id === "reviewImageModal") {
      closeReviewImageModal();
    }
  }

  document.addEventListener("keydown", function(event) {
    if (event.key === "Escape") {
      closeProductLightbox();
      closeReviewImageModal();
    }

    if (galleryImages.length > 1 && !document.getElementById("productLightbox")?.classList.contains("is-open")) {
      if (event.key === "ArrowLeft") {
        changeGallerySlide(-1);
      }
      if (event.key === "ArrowRight") {
        changeGallerySlide(1);
      }
    }
  });

  renderGallery();
</script>
