<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <%
    const currentStore = typeof store !== "undefined" ? store : null;
    const currentCart = typeof cart !== "undefined" ? cart : [];
    const currentStoreBasePath = typeof storeBasePath !== "undefined" && storeBasePath
      ? storeBasePath
      : (currentStore?.slug ? `/s/${currentStore.slug}` : "/tienda");
    const primaryColor = currentStore?.primaryColor || "#198754";
    const secondaryColor = currentStore?.secondaryColor || "#212529";
    const backgroundColor = currentStore?.themeConfig?.backgroundColor || "#f5f5f5";
    const surfaceColor = currentStore?.themeConfig?.surfaceColor || "#ffffff";
    const buttonPrimaryColor = currentStore?.themeConfig?.buttonPrimaryColor || primaryColor;
    const buttonSecondaryColor = currentStore?.themeConfig?.buttonSecondaryColor || secondaryColor;
    const backgroundDecorMode = currentStore?.themeConfig?.backgroundDecorMode || "soft";
    const backgroundPattern = currentStore?.themeConfig?.backgroundPattern || "none";
    const backgroundDecorOpacity = Number(currentStore?.themeConfig?.backgroundDecorOpacity ?? 18);
    const backgroundImage = currentStore?.themeConfig?.backgroundImage ? `/uploads/${currentStore.themeConfig.backgroundImage}` : "";
    const surfaceRadius = Number(currentStore?.themeConfig?.surfaceRadius ?? 24);
    const buttonRadius = Number(currentStore?.themeConfig?.buttonRadius ?? 12);
    const storeLogo = currentStore?.logo ? `/uploads/${currentStore.logo}` : "/logo.jpeg";
    const currentRoutePath = typeof currentPath !== "undefined" ? currentPath : currentStoreBasePath;
    const popupStartDate = currentStore?.themeConfig?.popupStartDate || "";
    const popupEndDate = currentStore?.themeConfig?.popupEndDate || "";
    const todayDate = new Date().toISOString().slice(0, 10);
    const popupScheduled = (!popupStartDate || popupStartDate <= todayDate) && (!popupEndDate || popupEndDate >= todayDate);
    const popupMatchesPath = currentStore?.themeConfig?.popupOnlyHome === false
      ? true
      : (currentRoutePath === currentStoreBasePath || currentRoutePath === `${currentStoreBasePath}/`);
    const popupConfig = currentStore?.themeConfig?.popupEnabled && currentStore?.themeConfig?.popupImage && popupScheduled && popupMatchesPath
      ? {
          image: `/uploads/${currentStore.themeConfig.popupImage}`,
          title: currentStore.themeConfig.popupTitle || "",
          targetUrl: currentStore.themeConfig.popupTargetUrl || "",
          openInNewTab: currentStore.themeConfig.popupOpenInNewTab !== false,
          signature: [
            currentStore.slug || "store",
            currentStore.themeConfig.popupImage || "",
            currentStore.themeConfig.popupTargetUrl || "",
            currentStore.themeConfig.popupTitle || "",
            popupStartDate,
            popupEndDate,
            currentStore.themeConfig.popupOnlyHome === false ? "all-pages" : "home-only"
          ].join(":")
        }
      : null;
    const backgroundDecorImage = backgroundDecorMode === "mesh"
      ? `radial-gradient(circle at left 18%, color-mix(in srgb, ${primaryColor} ${backgroundDecorOpacity}%, white) 0%, transparent 50%), radial-gradient(circle at right 14%, color-mix(in srgb, ${secondaryColor} ${Math.max(backgroundDecorOpacity - 6, 8)}%, white) 0%, transparent 42%), radial-gradient(circle at left 86%, color-mix(in srgb, ${primaryColor} ${Math.max(backgroundDecorOpacity - 10, 6)}%, white) 0%, transparent 36%)`
      : backgroundDecorMode === "none"
        ? "none"
        : `radial-gradient(circle at left 16%, color-mix(in srgb, ${primaryColor} ${backgroundDecorOpacity}%, white) 0%, transparent 44%), radial-gradient(circle at right 88%, color-mix(in srgb, ${secondaryColor} ${Math.max(backgroundDecorOpacity - 8, 6)}%, white) 0%, transparent 32%)`;
    const backgroundPatternImage = backgroundPattern === "dots"
      ? `radial-gradient(circle, color-mix(in srgb, ${secondaryColor} 12%, transparent) 1px, transparent 1.5px)`
      : backgroundPattern === "grid"
        ? `linear-gradient(color-mix(in srgb, ${secondaryColor} 8%, transparent) 1px, transparent 1px), linear-gradient(90deg, color-mix(in srgb, ${secondaryColor} 8%, transparent) 1px, transparent 1px)`
        : backgroundPattern === "diagonal"
          ? `repeating-linear-gradient(135deg, color-mix(in srgb, ${secondaryColor} 7%, transparent) 0 10px, transparent 10px 24px)`
          : "none";
  %>

  <title><%= currentStore?.name || "Pawlia" %></title>

  <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">

  <style>
    :root {
      --brand-primary: <%= primaryColor %>;
      --brand-secondary: <%= secondaryColor %>;
      --brand-primary-soft: color-mix(in srgb, <%= primaryColor %> 16%, white);
      --store-background: <%= backgroundColor %>;
      --store-surface: <%= surfaceColor %>;
      --button-primary: <%= buttonPrimaryColor %>;
      --button-secondary: <%= buttonSecondaryColor %>;
      --button-primary-soft: color-mix(in srgb, <%= buttonPrimaryColor %> 14%, white);
      --surface-radius: <%= surfaceRadius %>px;
      --button-radius: <%= buttonRadius %>px;
    }

    body {
      background-color: var(--store-background);
      background-image:
        <%= backgroundImage ? `linear-gradient(rgba(255,255,255,0.72), rgba(255,255,255,0.82)), url('${backgroundImage}')` : "none" %>,
        <%- backgroundPatternImage %>,
        <%- backgroundDecorImage %>;
      background-repeat: no-repeat, repeat, no-repeat;
      background-size:
        <%= backgroundImage ? "cover" : "auto" %>,
        <%= backgroundPattern === "dots" ? "20px 20px" : backgroundPattern === "grid" ? "28px 28px" : backgroundPattern === "diagonal" ? "auto" : "auto" %>,
        34rem 34rem, 28rem 28rem, 26rem 26rem;
      background-position:
        center top,
        left top,
        -12rem 7rem, calc(100% + 8rem) 78%, -10rem calc(100% - 3rem);
      background-attachment: scroll, scroll, scroll;
      overflow-x: hidden;
    }

    .ad-box {
      background: var(--store-surface);
      border-radius: var(--surface-radius);
      padding: 10px;
      text-align: center;
      border: 1px solid #ddd;
    }

    .bg-white,
    .navbar.bg-white,
    .table.bg-white {
      background-color: var(--store-surface) !important;
    }

    .store-shell {
      position: relative;
    }

    .store-shell::before {
      content: "";
      position: fixed;
      inset: 0 0 auto 0;
      height: 6px;
      background: linear-gradient(90deg, var(--brand-primary), var(--brand-secondary));
      z-index: 1032;
    }

    .brand-logo {
      width: 58px;
      height: 58px;
      object-fit: contain;
      background: white;
      border-radius: 16px;
      padding: 6px;
      border: 1px solid rgba(0, 0, 0, 0.08);
      box-shadow: 0 10px 24px rgba(0, 0, 0, 0.08);
    }

    .store-shell .rounded-4,
    .store-shell .card,
    .store-shell .form-control,
    .store-shell .form-select {
      border-radius: var(--surface-radius) !important;
    }

    .store-shell .btn {
      border-radius: var(--button-radius) !important;
    }

    .store-shell .card {
      background: var(--store-surface);
    }

    .btn-brand {
      background: var(--button-primary);
      border-color: var(--button-primary);
      color: white;
    }

    .btn-brand:hover,
    .btn-brand:focus {
      background: var(--button-secondary);
      border-color: var(--button-secondary);
      color: white;
    }

    .btn-success {
      background: var(--button-primary);
      border-color: var(--button-primary);
    }

    .btn-success:hover,
    .btn-success:focus,
    .btn-success:active {
      background: var(--button-secondary) !important;
      border-color: var(--button-secondary) !important;
    }

    .btn-outline-success {
      color: var(--button-secondary);
      border-color: var(--button-secondary);
      background: transparent;
    }

    .btn-outline-success:hover,
    .btn-outline-success:focus,
    .btn-outline-success:active {
      color: white !important;
      background: var(--button-secondary) !important;
      border-color: var(--button-secondary) !important;
    }

    .form-check-input:checked {
      background-color: var(--button-primary);
      border-color: var(--button-primary);
    }

    .page-surface {
      background: var(--store-surface);
    }

    .brand-accent {
      color: var(--brand-primary);
    }

    .store-popup-backdrop {
      position: fixed;
      inset: 0;
      background: rgba(15, 23, 42, 0.58);
      display: none;
      align-items: center;
      justify-content: center;
      padding: 1.5rem;
      z-index: 1060;
      backdrop-filter: blur(6px);
    }

    .store-popup-backdrop.is-visible {
      display: flex;
    }

    .store-popup-card {
      position: relative;
      width: min(620px, 100%);
      border-radius: calc(var(--surface-radius) + 6px);
      overflow: hidden;
      background: #fff;
      box-shadow: 0 28px 80px rgba(15, 23, 42, 0.28);
      animation: popupEnter 180ms ease-out;
    }

    .store-popup-card img {
      width: 100%;
      display: block;
      max-height: 78vh;
      object-fit: cover;
    }

    .store-popup-close {
      position: absolute;
      top: 12px;
      right: 12px;
      width: 40px;
      height: 40px;
      border: 0;
      border-radius: 999px;
      background: rgba(15, 23, 42, 0.72);
      color: #fff;
      font-size: 1.1rem;
      line-height: 1;
      cursor: pointer;
      z-index: 2;
    }

    .store-popup-caption {
      position: absolute;
      inset: auto 0 0 0;
      padding: 1rem 1.25rem;
      background: linear-gradient(180deg, rgba(15,23,42,0.02), rgba(15,23,42,0.78));
      color: #fff;
    }

    @keyframes popupEnter {
      from { opacity: 0; transform: translateY(12px) scale(.98); }
      to { opacity: 1; transform: translateY(0) scale(1); }
    }

    @media (max-width: 991.98px) {
      .navbar .container {
        padding-inline: 0.5rem;
      }

      .brand-logo {
        width: 50px;
        height: 50px;
      }

      body {
        background-size:
          <%= backgroundImage ? "cover" : "auto" %>,
          <%= backgroundPattern === "dots" ? "18px 18px" : backgroundPattern === "grid" ? "24px 24px" : backgroundPattern === "diagonal" ? "auto" : "auto" %>,
          24rem 24rem, 20rem 20rem, 16rem 16rem;
        background-position:
          center top,
          left top,
          -11rem 6rem, calc(100% + 8rem) 82%, -9rem calc(100% - 2rem);
      }

      .store-popup-backdrop {
        padding: 1rem;
      }

      .store-popup-card {
        width: min(100%, 420px);
      }

      .store-popup-card img {
        max-height: 70vh;
      }
    }
  </style>
</head>
<body class="store-shell">
  <%
    let totalItems = 0;
    if (currentCart) {
      for (let i = 0; i < currentCart.length; i++) {
        totalItems += Number(currentCart[i].quantity) || 0;
      }
    }
  %>

  <nav class="navbar bg-white shadow-sm p-3 mb-4">
    <div class="container d-flex flex-wrap justify-content-between align-items-center gap-3">
      <a href="<%= currentStoreBasePath %>" class="d-flex align-items-center gap-3" style="text-decoration:none; color:black;">
        <img src="<%= storeLogo %>" alt="<%= currentStore?.name || 'Pawlia' %>" class="brand-logo">
        <div>
          <h4 class="m-0"><%= currentStore?.name || "Pawlia" %></h4>
          <small class="text-muted">
            <%= currentStore?.slug ? `Catalogo de ${currentStore.name}` : "Tienda para mascotas" %>
          </small>
        </div>
      </a>

      <form class="d-flex flex-grow-1" method="GET" action="<%= currentStoreBasePath %>" style="max-width:560px;">
        <input
          type="text"
          name="search"
          class="form-control me-2"
          placeholder="Buscar alimentos, accesorios, arenas..."
          value="<%= currentSearch || "" %>"
        >
        <button class="btn btn-brand">Buscar</button>
      </form>

      <div class="d-flex align-items-center gap-2">
        <a href="<%= `${currentStoreBasePath}/contacto` %>" class="btn btn-outline-secondary">
          Contactanos
        </a>
        <a href="<%= `${currentStoreBasePath}/cart` %>" class="btn btn-brand position-relative">
          Carrito

          <% if (totalItems > 0) { %>
            <span style="position:absolute; top:-8px; right:-8px; background:red; color:white; border-radius:50%; font-size:12px; padding:2px 6px;">
              <%= totalItems %>
            </span>
          <% } %>
        </a>
      </div>
    </div>
  </nav>

  <div class="container-fluid">
    <div class="row">
      <div class="col-md-2 d-none d-md-block">
        <% if (typeof sideAds !== "undefined" && sideAds?.left) { %>
          <div class="ad-box mb-3">
            <% if (sideAds.left.targetUrl) { %>
              <a href="<%= sideAds.left.targetUrl %>" target="_blank" rel="noopener noreferrer">
                <img src="/uploads/<%= sideAds.left.image %>" class="img-fluid rounded" alt="<%= sideAds.left.title || 'Publicidad izquierda' %>">
              </a>
            <% } else { %>
              <img src="/uploads/<%= sideAds.left.image %>" class="img-fluid rounded" alt="<%= sideAds.left.title || 'Publicidad izquierda' %>">
            <% } %>
          </div>
        <% } %>
      </div>

      <div class="col-md-8">
        <%- body %>
      </div>

      <div class="col-md-2 d-none d-md-block">
        <% if (typeof sideAds !== "undefined" && sideAds?.right) { %>
          <div class="ad-box mb-3">
            <% if (sideAds.right.targetUrl) { %>
              <a href="<%= sideAds.right.targetUrl %>" target="_blank" rel="noopener noreferrer">
                <img src="/uploads/<%= sideAds.right.image %>" class="img-fluid rounded" alt="<%= sideAds.right.title || 'Publicidad derecha' %>">
              </a>
            <% } else { %>
              <img src="/uploads/<%= sideAds.right.image %>" class="img-fluid rounded" alt="<%= sideAds.right.title || 'Publicidad derecha' %>">
            <% } %>
          </div>
        <% } %>
      </div>
    </div>
  </div>

  <% if (popupConfig) { %>
    <div
      class="store-popup-backdrop"
      id="storePromoPopup"
      data-popup-signature="<%= popupConfig.signature %>"
    >
      <div class="store-popup-card">
        <button type="button" class="store-popup-close" aria-label="Cerrar popup" data-popup-close>&times;</button>
        <% if (popupConfig.targetUrl) { %>
          <a
            href="<%= popupConfig.targetUrl %>"
            class="d-block text-decoration-none"
            <%= /^https?:\/\//i.test(popupConfig.targetUrl) && popupConfig.openInNewTab ? 'target="_blank" rel="noopener noreferrer"' : '' %>
          >
            <img src="<%= popupConfig.image %>" alt="<%= popupConfig.title || 'Publicidad destacada' %>">
            <% if (popupConfig.title) { %>
              <div class="store-popup-caption">
                <div class="fw-semibold"><%= popupConfig.title %></div>
              </div>
            <% } %>
          </a>
        <% } else { %>
          <img src="<%= popupConfig.image %>" alt="<%= popupConfig.title || 'Publicidad destacada' %>">
          <% if (popupConfig.title) { %>
            <div class="store-popup-caption">
              <div class="fw-semibold"><%= popupConfig.title %></div>
            </div>
          <% } %>
        <% } %>
      </div>
    </div>
  <% } %>

  <script>
    (() => {
      const popup = document.getElementById("storePromoPopup");
      if (!popup) return;

      const popupKey = `store-popup-dismissed:${popup.dataset.popupSignature}`;
      if (sessionStorage.getItem(popupKey) === "1") {
        return;
      }

      const closePopup = () => {
        popup.classList.remove("is-visible");
        sessionStorage.setItem(popupKey, "1");
      };

      popup.classList.add("is-visible");

      popup.addEventListener("click", (event) => {
        if (event.target === popup) {
          closePopup();
        }
      });

      popup.querySelector("[data-popup-close]")?.addEventListener("click", closePopup);

      document.addEventListener("keydown", (event) => {
        if (event.key === "Escape" && popup.classList.contains("is-visible")) {
          closePopup();
        }
      });
    })();
  </script>
</body>
</html>
