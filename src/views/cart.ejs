<h2 class="mb-4">Tu carrito</h2>

<% if (errorMessage) { %>
  <div class="alert alert-danger"><%= errorMessage %></div>
<% } %>

<% if (successMessage) { %>
  <div class="alert alert-success"><%= successMessage %></div>
<% } %>

<% if (cart.length === 0) { %>
  <div class="text-center">
    <p>Tu carrito esta vacio</p>
    <a href="<%= storeBasePath %>" class="btn btn-success mt-2">
      Ir a la tienda
    </a>
  </div>
<% } %>

<% let total = 0; %>

<% if (cart.length > 0) { %>
  <table class="table table-bordered bg-white shadow">
    <thead class="table-dark">
      <tr>
        <th>Producto</th>
        <th style="width: 180px;">Cantidad</th>
        <th>Precio</th>
        <th>Total</th>
        <th></th>
      </tr>
    </thead>

    <tbody>
      <% cart.forEach(item => { total += item.price * item.quantity; %>
        <tr>
          <td>
            <%= item.name %>
            <% if (item.variantName) { %>
              <div><small class="text-muted">Variante: <%= item.variantName %></small></div>
            <% } %>
          </td>
          <td>
            <form method="POST" action="<%= `${storeBasePath}/cart/update/${item.cartKey}` %>" class="d-flex gap-2">
              <input type="hidden" name="_csrf" value="<%= csrfToken %>">
              <input
                type="number"
                name="quantity"
                min="1"
                step="1"
                value="<%= item.quantity %>"
                class="form-control form-control-sm"
              >
              <button type="submit" class="btn btn-outline-primary btn-sm">
                Actualizar
              </button>
            </form>
          </td>
          <td>$<%= Number(item.price).toLocaleString("es-CO") %></td>
          <td>$<%= Number(item.price * item.quantity).toLocaleString("es-CO") %></td>
          <td>
            <a href="<%= `${storeBasePath}/cart/remove/${item.cartKey}` %>" class="btn btn-danger btn-sm">
              Eliminar
            </a>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>

  <div class="d-flex justify-content-between align-items-center mt-4">
    <a href="<%= storeBasePath %>" class="btn btn-outline-secondary">
      Seguir comprando
    </a>

    <h4>Total: $<%= Number(total).toLocaleString("es-CO") %></h4>

    <a href="<%= `${storeBasePath}/checkout` %>" class="btn btn-success">
      Continuar compra
    </a>
  </div>
<% } %>
